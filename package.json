{
  "name": "mcpsmgr",
  "version": "0.4.0",
  "description": "Unified MCP server manager for multiple coding agents",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jtianling/mcps-manager.git"
  },
  "homepage": "https://github.com/jtianling/mcps-manager",
  "bugs": {
    "url": "https://github.com/jtianling/mcps-manager/issues"
  },
  "bin": {
    "mcpsmgr": "dist/index.js"
  },
  "files": [
    "dist",
    "schemas",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "mcp",
    "cli",
    "agent"
  ],
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@10.28.1",
  "dependencies": {
    "@inquirer/prompts": "^8.3.0",
    "commander": "^14.0.3",
    "json5": "^2.2.3",
    "smol-toml": "^1.6.0"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
