{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jtianling/mcps-manager/raw/HEAD/schemas/mcpsmgr.schema.json",
  "title": "mcpsmgr manifest",
  "description": "Manifest declared by an MCP server repository to enable mcpsmgr's manifest-driven add flow (npx mcpsmgr add <owner>/<repo>).",
  "type": "object",
  "required": ["schemaVersion", "name", "agents"],
  "additionalProperties": true,
  "properties": {
    "$schema": { "type": "string" },
    "schemaVersion": {
      "type": "string",
      "pattern": "^1\\.[0-9]+\\.[0-9]+$",
      "description": "Currently mcpsmgr accepts 1.x manifests."
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "Logical bundle name. Used in user-facing messaging."
    },
    "displayName": { "type": "string" },
    "description": { "type": "string" },
    "compatibility": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "npmPackage": {
          "type": "string",
          "description": "npm package name + semver range, e.g. 'cross-agent-teams-mcp@^0.5'. mcpsmgr warns if any agent server arg references the same package with a different range."
        }
      }
    },
    "variables": {
      "type": "object",
      "description": "Free-form named variables. Reference as ${name} in any string field below.",
      "additionalProperties": {
        "type": "object",
        "required": ["default"],
        "additionalProperties": false,
        "properties": {
          "default": { "type": "string" },
          "prompt": { "type": "string" },
          "required": { "type": "boolean" }
        }
      }
    },
    "envVars": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "required": { "type": "boolean" },
          "secret": { "type": "boolean" },
          "description": { "type": "string" },
          "appliedAs": {
            "type": "object",
            "required": ["kind", "name", "format"],
            "additionalProperties": false,
            "properties": {
              "kind": { "type": "string", "enum": ["header"] },
              "name": { "type": "string", "minLength": 1 },
              "format": {
                "type": "string",
                "pattern": "\\$\\{VALUE\\}",
                "description": "Must contain ${VALUE} self-reference. Cannot reference other variables."
              }
            }
          }
        }
      }
    },
    "prerequisites": {
      "type": "array",
      "description": "Print-only instructions. mcpsmgr never executes these.",
      "items": {
        "type": "object",
        "required": ["kind", "command"],
        "additionalProperties": false,
        "properties": {
          "kind": {
            "type": "string",
            "enum": ["long-running-command", "command"]
          },
          "description": { "type": "string" },
          "command": { "type": "string" },
          "notes": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "agents": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": false,
      "patternProperties": {
        "^(claude-code|codex|cursor|gemini-cli|opencode|antigravity|openclaw)$": {
          "type": "object",
          "required": ["servers"],
          "additionalProperties": false,
          "properties": {
            "servers": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "required": ["name", "config"],
                "additionalProperties": false,
                "properties": {
                  "name": { "type": "string", "minLength": 1 },
                  "config": {
                    "oneOf": [
                      {
                        "type": "object",
                        "required": ["transport", "command"],
                        "additionalProperties": false,
                        "properties": {
                          "transport": { "const": "stdio" },
                          "command": { "type": "string", "minLength": 1 },
                          "args": {
                            "type": "array",
                            "items": { "type": "string" }
                          },
                          "env": {
                            "type": "object",
                            "additionalProperties": { "type": "string" }
                          }
                        }
                      },
                      {
                        "type": "object",
                        "required": ["transport", "url"],
                        "additionalProperties": false,
                        "properties": {
                          "transport": {
                            "type": "string",
                            "enum": ["http", "streamable-http", "sse"]
                          },
                          "url": { "type": "string", "minLength": 1 },
                          "headers": {
                            "type": "object",
                            "additionalProperties": { "type": "string" }
                          }
                        }
                      }
                    ]
                  }
                }
              }
            },
            "postInstallNotes": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
